# SearXNG instance base URL (JSON output must be enabled server-side).
SEARXNG_BASE_URL=http://localhost:8888

# Per-request timeout (seconds) for provider HTTP calls.
# Valid: any positive number. Example: 5, 10, 15.
SEARCH_TIMEOUT_SECONDS=10

# Default max_results when the caller does not specify.
# Valid: 1..10 (upper bound enforced by the handler). Example: 5.
DEFAULT_MAX_RESULTS=5

# --- Brave Search ----------------------------------------------------
# Leave BRAVE_API_KEY empty to run in SearXNG-only mode. The server
# will log "Brave disabled" at startup and continue normally.
BRAVE_API_KEY=

# Brave Search API base URL. Change only if you are targeting a
# non-default Brave endpoint. Default: https://api.search.brave.com
# BRAVE_API_BASE=https://api.search.brave.com

# Optional two-letter country code sent as Brave's `country` param
# (localizes results). Unset by default — add in your local .env.
# Valid: ISO 3166-1 alpha-2. Examples: US, GB, SG, DE, JP.
# BRAVE_DEFAULT_COUNTRY=

# Optional UI language hint sent as Brave's `search_lang` param.
# Unset by default — add in your local .env.
# Valid: two-letter language code. Examples: en, es, fr, de, ja.
# BRAVE_DEFAULT_SEARCH_LANG=

# Brave SafeSearch filter level sent on every query.
# Valid: off | moderate | strict. Default: moderate.
BRAVE_SAFESEARCH=moderate

# --- Ranking ---------------------------------------------------------
# Window (in days) within which a result's published_date earns a
# recency bonus in the ranker. Tune for your domain's news cadence.
# Valid: any positive integer. Examples: 7, 30, 90. Default: 30.
RECENCY_WINDOW_DAYS=30
